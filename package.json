{
  "name": "castaminofen",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:web": "pnpm --filter @castaminofen/web dev",
    "dev:api": "pnpm --filter @castaminofen/api start:dev",
    "build": "pnpm --filter @castaminofen/shared-types build && pnpm --filter @castaminofen/web build && pnpm --filter @castaminofen/api build",
    "lint": "pnpm -r lint",
    "lint:web": "pnpm --filter @castaminofen/web lint",
    "lint:api": "pnpm --filter @castaminofen/api lint",
    "lint:fix": "pnpm exec eslint . --ext .ts,.tsx --fix"
  },
  "devDependencies": {
    "prettier": "^3.4.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "@typescript-eslint/parser": "^8.64.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0"
  }
}
